/target/
/debug/
Cargo.lock
*.rs.bk

# Generated Parquet outputs stay out of source control by default.
*.parquet
!tests/data/fixtures/*.parquet
*.rpf
!tests/data/fixtures/*.rpf

# Large or machine-local model datasets are kept outside the repo.
/data/
/tests/data/large/
/tests/data/external/*
!/tests/data/external/.gitkeep

# Vendor and exchange-case formats that should never be committed.
*.raw
*.RAW
*.dyr
*.DYR
*.sav
*.SAV
*.epc
*.EPC
*.pss
*.PSS
*.pdf
*.docx

# Internal-only marketing guide must never be committed.
INTERNAL-MARKETING-GUIDE.md
docs/roadmap.internal*

# Local Python virtual environment
.venv/
__pycache__/
*.pyc

# Local temp outputs
/tmp/
/.raptrix-test-data-root

# Local release packaging outputs (keep old tracked dist history untouched).
dist/raptrix-cim-rs-v*-windows-x86_64/
dist/raptrix-cim-rs-v*-windows-x86_64.zip
